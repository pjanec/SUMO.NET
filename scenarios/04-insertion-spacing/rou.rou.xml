<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Insertion spacing (rung 6). Four passenger vehicles (sigma=0) all request
         departure at t=0, pos=0, speed=0 on the same single-lane route. SUMO can only
         insert one at the lane start once a safe gap opens ahead, so they enter in a
         FIFO train (veh0@t0, veh1@t2, veh2@t5, veh3@t7). Isolates gap-gated insertion:
         insert iff (leaderBackPos - insertPos - minGap) >= 0. -->
    <vType id="passenger0" vClass="passenger" sigma="0"/>
    <route id="r0" edges="e0"/>
    <vehicle id="veh0" type="passenger0" route="r0" depart="0" departPos="0" departSpeed="0" departLane="0"/>
    <vehicle id="veh1" type="passenger0" route="r0" depart="0" departPos="0" departSpeed="0" departLane="0"/>
    <vehicle id="veh2" type="passenger0" route="r0" depart="0" departPos="0" departSpeed="0" departLane="0"/>
    <vehicle id="veh3" type="passenger0" route="r0" depart="0" departPos="0" departSpeed="0" departLane="0"/>
</routes>
