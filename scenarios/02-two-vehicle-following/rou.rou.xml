<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Two-vehicle following (rung 4). Both passenger, sigma=0 (deterministic).
         The leader is capped to maxSpeed=5 m/s so the fast follower catches it and
         settles into the Krauss steady-state gap: this exercises the real leader
         vsafe constraint and the deceleration bound, not just free-flow accel. -->
    <vType id="leader"   vClass="passenger" sigma="0" maxSpeed="5.00"/>
    <vType id="follower" vClass="passenger" sigma="0"/>
    <route id="r0" edges="e0"/>
    <vehicle id="veh0" type="leader"   route="r0" depart="0" departPos="100" departSpeed="0" departLane="0"/>
    <vehicle id="veh1" type="follower" route="r0" depart="0" departPos="0"   departSpeed="0" departLane="0"/>
</routes>
