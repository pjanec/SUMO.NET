<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- OV4 fixture: a slow leader holds up a fast lcOpposite overtaker on edge AB while a normal-
         speed oncoming vehicle approaches head-on down the opposite edge BA (starting worldX 350).
         The gap acceptance (OV2) commits to a full, clean pass; as the oncoming closes within the
         cooperative-shift reaction range WHILE the overtaker is still spilled across the centre line,
         the oncoming pulls to its OWN outer lane edge (cooperative shift, the mirror of the give-way
         drift) to widen the corridor, then recentres once the overtaker has recentred. The test
         asserts the oncoming shifts outward during the spill, both pass, no pair collides, and both
         recentre. (Same geometry as the OV1 overtake fixture, where OV2 still completes the pass
         safely; OV4 only adds the cooperative margin.) -->
    <vType id="slow" vClass="passenger" sigma="0" maxSpeed="6"/>
    <vType id="fast" vClass="passenger" sigma="0" maxSpeed="13.89" lcOpposite="true"/>
    <vType id="onc"  vClass="passenger" sigma="0" maxSpeed="13.89"/>
    <route id="ab" edges="AB"/>
    <route id="ba" edges="BA"/>
    <vehicle id="leader"    type="slow" route="ab" depart="0" departPos="100" departSpeed="0" departLane="0"/>
    <vehicle id="overtaker" type="fast" route="ab" depart="0" departPos="60"  departSpeed="0" departLane="0"/>
    <vehicle id="oncoming"  type="onc"  route="ba" depart="0" departPos="650" departSpeed="0" departLane="0"/>
</routes>
