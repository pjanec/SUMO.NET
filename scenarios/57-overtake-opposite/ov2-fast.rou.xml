<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- OV2 speed-dependence fixture (fast oncoming). Identical held-up overtaker and identical
         oncoming START position (BA pos 800 -> worldX ~200); only the oncoming maxSpeed differs
         (30). A fixed-distance (OV1) rule would give the SAME answer for both; OV2's closing-speed
         gap acceptance accepts the SLOW oncoming and refuses the FAST one at this same distance. -->
    <vType id="slow" vClass="passenger" sigma="0" maxSpeed="6"/>
    <vType id="fast" vClass="passenger" sigma="0" maxSpeed="13.89" lcOpposite="true"/>
    <vType id="onc"  vClass="passenger" sigma="0" maxSpeed="30"/>
    <route id="ab" edges="AB"/>
    <route id="ba" edges="BA"/>
    <vehicle id="leader"    type="slow" route="ab" depart="0" departPos="100" departSpeed="0" departLane="0"/>
    <vehicle id="overtaker" type="fast" route="ab" depart="0" departPos="60"  departSpeed="0" departLane="0"/>
    <vehicle id="oncoming"  type="onc"  route="ba" depart="0" departPos="800" departSpeed="30" departLane="0"/>
</routes>
