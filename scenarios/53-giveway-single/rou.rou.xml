<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- ER3/ER5 behavioral-test fixture: a single-lane 500 m road. A slow regular car (car0,
         maxSpeed capped to 6) drives ahead; a blue-light EMERGENCY vehicle (ev, hasBluelight="true")
         starts behind and catches up. There is NO SUMO golden (SUMO's lane-based model cannot form a
         rescue lane on a single lane at all; this is our enhancement). Behavioral property tests:
         ER3: car0 forms a give-way intent (GiveWaySide != 0) once ev is within the 25 m siren range
                behind it, and stays inert (0) before that / when no EV is present.
         ER5: car0 pulls to the lane edge (LatOffset drifts off-centre) and the EV passes without a
                collision, then car0 recenters after the EV clears. -->
    <vType id="car" vClass="passenger" sigma="0" maxSpeed="6"/>
    <vType id="emg" vClass="emergency" sigma="0" maxSpeed="13.89" hasBluelight="true"/>
    <route id="r0" edges="e0"/>
    <vehicle id="car0" type="car" route="r0" depart="0" departPos="60" departSpeed="0" departLane="0"/>
    <vehicle id="ev"   type="emg" route="r0" depart="0" departPos="0"  departSpeed="0" departLane="0"/>
</routes>
